{
    "permissions": {
        "allow": [
            "Read(**)",
            "Edit(src/**)",
            "Edit(app/**)",
            "Edit(public/**)",
            "Edit(*.md)",
            "Edit(*.json)",
            "Edit(*.ts)",
            "Edit(*.tsx)",
            "Edit(*.js)",
            "Edit(*.jsx)",
            "Edit(.env.example)",
            "Edit(tailwind.config.*)",
            "Edit(next.config.*)",
            "Edit(tsconfig.json)",
            "Bash(npm install)",
            "Bash(npm install:*)",
            "Bash(npm run:*)",
            "Bash(npx create-next-app:*)",
            "Bash(git status)",
            "Bash(git diff:*)",
            "Bash(git log:*)",
            "Bash(git add:*)",
            "Bash(git commit:*)",
            "Bash(git push:*)",
            "Bash(git pull:*)",
            "Bash(git checkout:*)",
            "Bash(git branch:*)",
            "Bash(ls:*)",
            "Bash(cat:*)",
            "Bash(mkdir:*)",
            "Bash(touch:*)"
        ],
        "deny": [
            "Read(**/.env)",
            "Read(**/.env.local)",
            "Read(**/.env.*.local)",
            "Read(**/.env.production)",
            "Read(**/credentials.json)",
            "Read(**/*.pem)",
            "Read(**/*.key)",
            "Read(**/.ssh/**)",
            "Read(~/.aws/**)",
            "Read(~/.config/gcloud/**)",
            "Edit(.env)",
            "Edit(.env.local)",
            "Edit(.env.production)",
            "Bash(sudo:*)",
            "Bash(su:*)",
            "Bash(curl:*)",
            "Bash(wget:*)",
            "Bash(ssh:*)",
            "Bash(scp:*)",
            "Bash(rm -rf:*)",
            "Bash(chmod 777:*)",
            "Bash(git push --force:*)",
            "Bash(git push -f:*)"
        ]
    },
    "env": {
        "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1"
    }
}